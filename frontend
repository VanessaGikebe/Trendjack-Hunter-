<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Internet Has A Pulse</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #F5F5F2;
    --black: #050505;
    --purple: #B764FF;
    --lime: #E6FF52;
    --white: #FFFFFF;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--black);
    font-family: 'Arial Black', 'Helvetica Neue', Arial, sans-serif;
    overflow-x: hidden;
  }

  /* ─── NOISE TEXTURE ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px;
    mix-blend-mode: multiply;
  }
  .nav-logo {
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .nav-cta {
    background: var(--black);
    color: var(--bg);
    border: none;
    padding: 10px 24px;
    font-family: inherit;
    font-weight: 900;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .nav-cta:hover { background: var(--purple); color: #fff; }

  /* ─── HERO ─── */
  #hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-text-bg {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    pointer-events: none;
    padding: 0 30px;
    z-index: 1;
  }

  .hero-word {
    font-size: clamp(80px, 14vw, 200px);
    font-weight: 900;
    letter-spacing: -8px;
    line-height: 0.88;
    text-transform: uppercase;
    color: var(--black);
    display: block;
    transition: opacity 0.8s ease, transform 0.8s ease, filter 0.8s ease;
    will-change: transform, opacity;
  }
  .hero-word.w1 { padding-left: 2vw; }
  .hero-word.w2 { padding-left: 0vw; }
  .hero-word.w3 { padding-left: 5vw; }
  .hero-word.w4 { padding-left: 1vw; font-size: clamp(60px, 10vw, 140px); }

  /* ─── PHONE ─── */
  .phone-wrapper {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translateX(-50%) translateY(-50%) rotateY(8deg) rotateX(-3deg);
    z-index: 10;
    animation: phoneFloat 6s ease-in-out infinite;
    perspective: 1200px;
  }

  @keyframes phoneFloat {
    0%, 100% { transform: translateX(-50%) translateY(-50%) rotateY(8deg) rotateX(-3deg) translateY(0px); }
    50% { transform: translateX(-50%) translateY(-52%) rotateY(10deg) rotateX(-4deg) translateY(-8px); }
  }

  .phone {
    width: 200px;
    height: 400px;
    background: var(--black);
    border-radius: 36px;
    position: relative;
    box-shadow:
      0 0 0 2px #333,
      0 40px 80px rgba(0,0,0,0.4),
      0 0 60px rgba(183,100,255,0.15);
    overflow: hidden;
  }

  .phone-notch {
    position: absolute;
    top: 14px; left: 50%;
    transform: translateX(-50%);
    width: 60px; height: 10px;
    background: #111;
    border-radius: 8px;
    z-index: 2;
  }

  .phone-screen {
    position: absolute;
    inset: 8px;
    background: #0a0a0a;
    border-radius: 28px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .phone-status {
    padding: 18px 16px 6px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 8px;
    color: #888;
    font-weight: 700;
  }

  .phone-content {
    flex: 1;
    padding: 8px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;
  }

  .phone-label {
    font-size: 7px;
    color: var(--purple);
    letter-spacing: 2px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .phone-trend-item {
    position: absolute;
    inset: 0;
    padding: 30px 12px 12px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .phone-trend-item.active {
    opacity: 1;
    transform: translateY(0);
  }
  .phone-trend-item.exit {
    opacity: 0;
    transform: translateY(-20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .ptr-tag {
    font-size: 8px;
    color: var(--purple);
    letter-spacing: 2px;
    font-weight: 900;
    text-transform: uppercase;
  }
  .ptr-title {
    font-size: 13px;
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
  }
  .ptr-stat {
    font-size: 22px;
    font-weight: 900;
    color: var(--lime);
    letter-spacing: -1px;
  }
  .ptr-sub {
    font-size: 7px;
    color: #666;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .ptr-bar {
    height: 2px;
    background: #222;
    border-radius: 2px;
    margin-top: 4px;
  }
  .ptr-bar-fill {
    height: 100%;
    background: var(--purple);
    border-radius: 2px;
    animation: barPulse 2s ease-in-out infinite;
  }
  @keyframes barPulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }

  /* ─── FLOATING CARDS ─── */
  .float-card {
    position: absolute;
    z-index: 20;
    border-radius: 14px;
    padding: 14px 18px;
    min-width: 140px;
    font-family: 'Arial Black', Arial, sans-serif;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
    transition: transform 0.3s ease;
  }
  .float-card:hover { transform: scale(1.05) !important; }

  .fc-lime { background: var(--lime); color: var(--black); }
  .fc-purple { background: var(--purple); color: #fff; }
  .fc-white { background: #fff; color: var(--black); border: 1px solid rgba(0,0,0,0.06); }
  .fc-dark { background: var(--black); color: #fff; }

  .fc-hashtag { font-size: 11px; font-weight: 900; letter-spacing: 1px; }
  .fc-pct { font-size: 22px; font-weight: 900; letter-spacing: -1px; }
  .fc-label { font-size: 11px; font-weight: 700; }
  .fc-sub { font-size: 9px; opacity: 0.7; margin-top: 2px; letter-spacing: 0.5px; }

  /* card positions & animations */
  .fc-1 { top: 12%; left: 5%; animation: float1 7s ease-in-out infinite alternate; }
  .fc-2 { top: 8%; right: 8%; animation: float2 8.5s ease-in-out infinite alternate; }
  .fc-3 { top: 38%; left: 3%; animation: float3 6s ease-in-out infinite alternate; }
  .fc-4 { bottom: 22%; left: 6%; animation: float4 9s ease-in-out infinite alternate; }
  .fc-5 { top: 25%; right: 4%; animation: float5 7.5s ease-in-out infinite alternate; }
  .fc-6 { bottom: 18%; right: 5%; animation: float6 6.5s ease-in-out infinite alternate; }

  @keyframes float1 { from { transform: translateY(0) rotate(-2deg); } to { transform: translateY(-12px) rotate(1deg); } }
  @keyframes float2 { from { transform: translateY(0) rotate(1deg); } to { transform: translateY(-16px) rotate(-2deg); } }
  @keyframes float3 { from { transform: translateY(0) rotate(-1deg); } to { transform: translateY(10px) rotate(2deg); } }
  @keyframes float4 { from { transform: translateY(0) rotate(2deg); } to { transform: translateY(-14px) rotate(-1deg); } }
  @keyframes float5 { from { transform: translateY(0) rotate(-2deg); } to { transform: translateY(12px) rotate(1.5deg); } }
  @keyframes float6 { from { transform: translateY(0) rotate(1.5deg); } to { transform: translateY(-10px) rotate(-2deg); } }

  /* ─── SCROLL TRANSITION SECTION ─── */
  #transition-zone {
    position: relative;
    height: 300vh;
  }

  #sticky-transition {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .transition-bg {
    position: absolute;
    inset: 0;
    background: var(--bg);
    transition: background 0.1s;
  }

  .trans-text-old {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 30px;
    pointer-events: none;
  }

  .trans-hero-word {
    font-size: clamp(60px, 11vw, 160px);
    font-weight: 900;
    letter-spacing: -6px;
    line-height: 0.88;
    text-transform: uppercase;
    color: var(--black);
    display: block;
    will-change: transform, opacity;
  }

  .trans-text-new {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
  }

  .trans-new-word {
    font-size: clamp(70px, 13vw, 190px);
    font-weight: 900;
    letter-spacing: -8px;
    line-height: 0.85;
    text-transform: uppercase;
    color: var(--purple);
    display: block;
    text-align: center;
  }

  .trans-phone-anchor {
    position: absolute;
    left: 50%; top: 50%;
    transform: translateX(-50%) translateY(-50%);
    z-index: 10;
    pointer-events: none;
    transition: none;
  }

  /* ─── SECTION 2: CURRENT TRENDS ─── */
  #section-trends {
    background: var(--black);
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .trends-center {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 60px;
    padding: 80px 20px;
  }

  .trends-title {
    text-align: center;
    pointer-events: none;
  }
  .trends-label {
    font-size: 11px;
    letter-spacing: 5px;
    color: var(--purple);
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .trends-heading {
    font-size: clamp(50px, 8vw, 110px);
    font-weight: 900;
    letter-spacing: -5px;
    line-height: 0.88;
    color: #fff;
    text-transform: uppercase;
  }
  .trends-heading .accent { color: var(--purple); }

  .trends-phone-area {
    position: relative;
    width: 600px;
    height: 500px;
    max-width: 100vw;
  }

  .trends-phone {
    position: absolute;
    left: 50%; top: 50%;
    transform: translateX(-50%) translateY(-50%) rotateY(8deg) rotateX(-3deg);
    animation: phoneFloat 6s ease-in-out infinite;
    z-index: 10;
  }

  /* Dense floating tags around trends phone */
  .trend-tag {
    position: absolute;
    z-index: 5;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 16px;
    border-radius: 100px;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
  }
  .tt-purple { background: rgba(183,100,255,0.15); color: var(--purple); border: 1px solid rgba(183,100,255,0.3); }
  .tt-lime { background: rgba(230,255,82,0.1); color: var(--lime); border: 1px solid rgba(230,255,82,0.3); }
  .tt-white { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.1); }

  .tt-1  { top: 5%;   left: 2%;   animation: ttagFloat1 5s ease-in-out infinite alternate; }
  .tt-2  { top: 20%;  right: 3%;  animation: ttagFloat2 7s ease-in-out infinite alternate; }
  .tt-3  { top: 40%;  left: 0%;   animation: ttagFloat3 6s ease-in-out infinite alternate; }
  .tt-4  { top: 60%;  right: 5%;  animation: ttagFloat4 5.5s ease-in-out infinite alternate; }
  .tt-5  { bottom: 8%; left: 10%; animation: ttagFloat5 8s ease-in-out infinite alternate; }
  .tt-6  { bottom: 5%; right: 10%; animation: ttagFloat6 6.5s ease-in-out infinite alternate; }
  .tt-7  { top: 5%;   right: 20%; animation: ttagFloat1 7.5s ease-in-out infinite alternate; }
  .tt-8  { bottom: 20%; left: 5%; animation: ttagFloat3 5.5s ease-in-out infinite alternate; }

  @keyframes ttagFloat1 { from { transform: translateY(0); } to { transform: translateY(-10px); } }
  @keyframes ttagFloat2 { from { transform: translateY(0); } to { transform: translateY(8px); } }
  @keyframes ttagFloat3 { from { transform: translateY(0) rotate(-1deg); } to { transform: translateY(-12px) rotate(1deg); } }
  @keyframes ttagFloat4 { from { transform: translateY(0); } to { transform: translateY(10px); } }
  @keyframes ttagFloat5 { from { transform: translateY(0) rotate(1deg); } to { transform: translateY(-8px) rotate(-1deg); } }
  @keyframes ttagFloat6 { from { transform: translateY(0); } to { transform: translateY(-14px); } }

  /* ─── SIGNALS SECTION ─── */
  #section-signals {
    background: var(--bg);
    padding: 120px 40px;
    position: relative;
    overflow: hidden;
  }

  .signals-header {
    margin-bottom: 80px;
  }
  .signals-eyebrow {
    font-size: 11px;
    letter-spacing: 5px;
    color: var(--purple);
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .signals-title {
    font-size: clamp(50px, 8vw, 110px);
    font-weight: 900;
    letter-spacing: -5px;
    line-height: 0.88;
    text-transform: uppercase;
    color: var(--black);
  }
  .signals-sub {
    font-size: 14px;
    color: #666;
    font-weight: 400;
    font-family: Georgia, serif;
    font-style: italic;
    margin-top: 16px;
    max-width: 400px;
    letter-spacing: 0;
  }

  /* MacBook scroll section */
  #section-macbook {
    background: var(--black);
    padding: 120px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .macbook-header {
    text-align: center;
    margin-bottom: 80px;
  }
  .macbook-eyebrow {
    font-size: 11px;
    letter-spacing: 5px;
    color: var(--lime);
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .macbook-title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 900;
    letter-spacing: -4px;
    line-height: 0.9;
    text-transform: uppercase;
    color: #fff;
  }

  .macbook-wrap {
    width: 100%;
    max-width: 700px;
    position: relative;
    perspective: 1200px;
  }

  .macbook-body {
    background: #1a1a1a;
    border-radius: 12px 12px 0 0;
    padding: 20px 20px 0;
    border: 1px solid #333;
    border-bottom: none;
    position: relative;
  }
  .macbook-camera {
    width: 8px; height: 8px;
    background: #444;
    border-radius: 50%;
    margin: 0 auto 16px;
  }
  .macbook-screen-wrap {
    background: #050505;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    min-height: 360px;
  }

  .macbook-base {
    background: #222;
    height: 16px;
    border-radius: 0 0 8px 8px;
    border: 1px solid #333;
    border-top: none;
  }
  .macbook-foot {
    background: #1a1a1a;
    height: 6px;
    width: 40%;
    margin: 0 auto;
    border-radius: 0 0 6px 6px;
  }

  /* Live dashboard inside macbook */
  .dashboard {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .dash-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .dash-title { font-size: 10px; letter-spacing: 3px; color: #666; font-weight: 700; text-transform: uppercase; }
  .dash-live { display: flex; align-items: center; gap: 6px; font-size: 9px; color: var(--purple); font-weight: 700; letter-spacing: 2px; }
  .dash-dot { width: 6px; height: 6px; background: var(--purple); border-radius: 50%; animation: livePulse 1.5s ease-in-out infinite; }
  @keyframes livePulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.8); } }

  .dash-row {
    display: flex;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid #111;
    gap: 16px;
  }
  .dash-rank { font-size: 9px; color: #444; font-weight: 700; width: 20px; }
  .dash-name { flex: 1; font-size: 11px; font-weight: 900; color: #ddd; letter-spacing: 0.5px; }
  .dash-bar-wrap { width: 100px; height: 3px; background: #1a1a1a; border-radius: 2px; }
  .dash-bar-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }
  .dash-pct { font-size: 12px; font-weight: 900; letter-spacing: -0.5px; min-width: 55px; text-align: right; }

  .c-lime { color: var(--lime); }
  .c-purple { color: var(--purple); }
  .c-white { color: #fff; }

  /* ─── ORBITAL CAROUSEL ─── */
  #section-orbital {
    background: var(--bg);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 80px 20px;
    overflow: hidden;
  }

  .orbital-header {
    text-align: center;
    margin-bottom: 60px;
    z-index: 20;
    position: relative;
  }
  .orbital-eyebrow {
    font-size: 11px;
    letter-spacing: 5px;
    color: var(--purple);
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .orbital-title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 900;
    letter-spacing: -4px;
    line-height: 0.88;
    text-transform: uppercase;
    color: var(--black);
  }

  .orbital-stage {
    position: relative;
    width: 680px;
    height: 680px;
    max-width: 95vw;
    max-height: 95vw;
  }

  .orbital-center {
    position: absolute;
    left: 50%; top: 50%;
    transform: translateX(-50%) translateY(-50%);
    width: 180px; height: 180px;
    border-radius: 50%;
    background: var(--black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 30;
    box-shadow: 0 0 60px rgba(183,100,255,0.2);
  }
  .orbital-center-label {
    font-size: 8px;
    letter-spacing: 3px;
    color: var(--purple);
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .orbital-center-title {
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 1px;
    color: #fff;
    text-align: center;
    text-transform: uppercase;
  }

  /* Orbit rings */
  .orbit-ring {
    position: absolute;
    left: 50%; top: 50%;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.07);
    transform: translateX(-50%) translateY(-50%);
    pointer-events: none;
  }
  .orbit-ring-1 { width: 340px; height: 340px; }
  .orbit-ring-2 { width: 520px; height: 520px; border-color: rgba(183,100,255,0.1); }
  .orbit-ring-3 { width: 650px; height: 650px; border-color: rgba(0,0,0,0.04); }

  /* Orbit items */
  .orbit-item {
    position: absolute;
    left: 50%; top: 50%;
    z-index: 20;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .orbit-card {
    padding: 10px 16px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 2px;
    text-transform: uppercase;
    white-space: nowrap;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
    transform: translateX(-50%) translateY(-50%);
    display: block;
    position: relative;
  }

  .orbit-card.oc-lime { background: var(--lime); color: var(--black); }
  .orbit-card.oc-purple { background: var(--purple); color: #fff; }
  .orbit-card.oc-dark { background: var(--black); color: #fff; }
  .orbit-card.oc-white { background: #fff; color: var(--black); border: 1px solid rgba(0,0,0,0.08); }

  .orbit-item:hover .orbit-card { transform: translateX(-50%) translateY(-50%) scale(1.2); box-shadow: 0 8px 40px rgba(0,0,0,0.2); }

  /* Hover tooltip */
  .orbit-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--black);
    color: #fff;
    border-radius: 12px;
    padding: 14px 16px;
    min-width: 180px;
    font-size: 9px;
    z-index: 50;
    pointer-events: none;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
  }
